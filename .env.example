# Twilio Configuration (optional for receiving webhooks — only needed for outbound/test scripts)
# Get these from https://console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# Flask Configuration (local dev; Cloud Run sets PORT automatically)
PORT=8080
FLASK_DEBUG=False

# Instructions:
# 1. Copy this file to .env
# 2. For local Twilio test sends, fill in Twilio credentials above
# 3. Never commit .env to git!
# 4. Cloud Run: see docs/DEPLOY_GCP.md (no Twilio secrets required on the server for inbound WhatsApp)
